---
// Feather-style line icons, emitted as static inline SVG at build time
// (the kit injected these via JS — here they ship in the HTML).
interface Props { name: keyof typeof paths; size?: number; }

const paths = {
  arrow: 'M5 12h14M13 6l6 6-6 6',
  route: 'M6 19a3 3 0 1 0 0-6 3 3 0 0 0 0 6zM18 11a3 3 0 1 0 0-6 3 3 0 0 0 0 6zM9 16h6a3 3 0 0 0 3-3',
  tag: 'M20.6 13.4 13.4 20.6a2 2 0 0 1-2.8 0l-7-7A2 2 0 0 1 3 12V5a2 2 0 0 1 2-2h7a2 2 0 0 1 1.4.6l7.2 7.2a2 2 0 0 1 0 2.6zM7.5 7.5h.01',
  chart: 'M3 3v18h18M7 15l4-4 3 3 5-6',
  shield: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
  refresh: 'M23 4v6h-6M1 20v-6h6M3.5 9a9 9 0 0 1 14.9-3.4L23 10M1 14l4.6 4.4A9 9 0 0 0 20.5 15',
  bell: 'M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9M13.7 21a2 2 0 0 1-3.4 0',
  check: 'M20 6 9 17l-5-5',
  plus: 'M12 5v14M5 12h14',
} as const;

const { name, size } = Astro.props;
const style = size ? `width:${size}px;height:${size}px;` : undefined;
---
<svg class="ic" viewBox="0 0 24 24" style={style} aria-hidden="true" set:html={`<path d="${paths[name]}"></path>`}></svg>
