---
import Base from '../layouts/Base.astro';
import Helm from '../components/Helm.astro';
import Icon from '../components/Icon.astro';
import Waves from '../components/Waves.astro';
import { site, trust, workspace, steps, caps, roadmap, story, faqs } from '../data/content.ts';
---
<Base>
  <!-- HERO -->
  <header class="hero" id="top">
    <Waves />
    <div class="radar"><div class="glow"></div></div>
    <div class="wrap hero-in">
      <span class="eyebrow"><Helm size={15} />{site.tagline}</span>
      <h1>Talk to your<br /><span class="a">telecom stack.</span></h1>
      <p class="lead">A unified chat that ties into your back-end systems and the AI provider of your choice — so you can pull data, build reports, and answer the hard questions just by asking.</p>
      <div class="cta">
        <a class="btn btn-primary" href="#contact">Request a demo <Icon name="arrow" /></a>
        <a class="btn btn-ghost" href="#workspace">See how it works</a>
      </div>
    </div>
  </header>

  <!-- TRUST -->
  <div class="trust"><div class="wrap trust-in">
    <span class="label">Built for the carriers in the middle</span>
    <div class="names">{trust.map((t) => <span>{t}</span>)}</div>
  </div></div>

  <!-- THE WORKSPACE — main thrust: one unified chat over your stack -->
  <section class="block" id="workspace">
    <div class="wrap split">
      <div>
        <span class="eyebrow">The workspace</span>
        <h2>{workspace.heading}</h2>
        <p class="muted" style="margin-top:18px;">{workspace.lead}</p>
        <ul class="checklist">
          {workspace.bullets.map((b) => (
            <li>
              <span class="chk"><Icon name="check" size={14} /></span>
              <span><b>{b.lead}</b>{b.rest}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="frame">
        <div class="bar"><span class="dot"></span><span class="dot"></span><span class="dot"></span><span class="url">app.telcoos.io</span></div>
        <div class="shot">
          <img src="/workspace.png" width="1400" height="880" loading="lazy" alt="The TelcoOS workspace — a single chat surface that pulls billing, routing, records, and rate decks into one conversation." />
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="block band" id="how">
    <div class="wrap">
      <div class="sec-head">
        <span class="eyebrow">How it works</span>
        <h2>Connect. Choose your AI. Just ask.</h2>
        <p>No rip-and-replace. TelcoOS sits on top of the systems you already run and the AI provider you already trust.</p>
      </div>
      <div class="steps">
        {steps.map((s) => (
          <div class="step">
            <div class="n">{s.n}</div>
            <div class="ico"><Icon name={s.icon} /></div>
            <h3>{s.title}</h3>
            <p>{s.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CAPABILITIES -->
  <section class="block" id="caps">
    <div class="wrap">
      <div class="sec-head">
        <span class="eyebrow">Capabilities</span>
        <h2>An operator’s instincts, a data scientist’s reach.</h2>
      </div>
      <div class="caps">
        {caps.map((c) => (
          <div class="cap">
            <div class="ico"><Icon name={c.icon} /></div>
            <h3>{c.title}</h3>
            <p>{c.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- IN ACTION — a real, current session (proof) -->
  <section class="block" id="story">
    <div class="wrap">
      <div class="sec-head story-in">
        <span class="eyebrow">In action</span>
        <h2>A real session.</h2>
      </div>
      <div class="story-in">
        <p class="story-lead">{story.lead}</p>
        <div class="timeline">
          {story.steps.map((s) => (
            <div class="tl-step"><p><b>{s.lead}</b>{s.rest}</p></div>
          ))}
        </div>
        <p class="story-outcome">{story.outcome}</p>
      </div>
    </div>
  </section>

  <!-- ROADMAP -->
  <section class="block band" id="roadmap">
    <div class="wrap">
      <div class="sec-head">
        <span class="eyebrow" style="gap:12px;">Roadmap <span class="badge">In development</span></span>
        <h2>Where it’s headed.</h2>
        <p>{roadmap.intro}</p>
      </div>
      <div class="road">
        {roadmap.items.map((r) => (
          <div class="road-item">
            <h3>{r.title}</h3>
            <p>{r.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="block" id="faq">
    <div class="wrap" style="max-width:880px;">
      <div class="sec-head"><span class="eyebrow">FAQ</span><h2>Questions, answered.</h2></div>
      <div class="faq">
        {faqs.map((f) => (
          <details class="faq-item">
            <summary class="faq-q">{f.q} <span class="pm"><Icon name="plus" /></span></summary>
            <div class="faq-a"><div class="inner">{f.a}</div></div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="final" id="contact">
    <Waves bottom={true} />
    <div class="radar"><div class="glow" style="left:50%;top:-200px;transform:translateX(-50%);"></div></div>
    <div class="wrap" style="position:relative;">
      <h2>Put your whole stack<br />in one chat.</h2>
      <p>See TelcoOS run on your systems and your AI provider — book a walkthrough with the team.</p>
      <div class="cta">
        <a class="btn btn-primary" href={`mailto:${site.contactEmail}`}>Request a demo <Icon name="arrow" /></a>
        <a class="btn btn-ghost" href="#top">Back to top</a>
      </div>
    </div>
  </section>
</Base>
